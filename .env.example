# Copy this file to .env and fill in real values. Never commit the real .env.

# Server
PORT=8080
ENVIRONMENT=development

# Postgres connection string — works with Supabase, Neon, or any Postgres host.
# Supabase example:
#   postgres://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
# Neon example:
#   postgres://[user]:[password]@[endpoint].neon.tech/[dbname]?sslmode=require
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# Long, random string used to sign auth JWTs. Generate one with:
#   openssl rand -base64 48
JWT_SECRET=change-this-to-a-long-random-string

# Google OAuth2 web client credentials. Create these at:
#   https://console.cloud.google.com/apis/credentials
# Create an "OAuth client ID" of type "Web application". Add the redirect
# URL below to "Authorized redirect URIs" on that client.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Must exactly match an Authorized redirect URI on the OAuth client above.
GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/google/callback

# Where the browser is sent after OAuth login completes. Leave empty for
# the default same-process setup (this server serves both API + frontend).
# Only set this if the frontend is hosted on a different domain — see
# README "Hosting the frontend separately".
FRONTEND_BASE_URL=

# Comma-separated list of origins allowed to call the API with credentials.
# Only needed if you host the frontend on a different domain/port than the
# backend. Leave unset (defaults to "*") for local dev or same-origin setups.
# Example: ALLOWED_ORIGINS=https://dsa-tracker.vercel.app,http://localhost:5500
ALLOWED_ORIGINS=
